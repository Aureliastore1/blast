# =============================================================================
# iNaedaa Blast — Environment Configuration Example
# Copy this file to .env in apps/api and apps/web (or root, loaded via docker-compose)
# =============================================================================

# ---------- General ----------
NODE_ENV=development
APP_NAME="iNaedaa Blast"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---------- API Server ----------
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ---------- Database (PostgreSQL) ----------
DATABASE_URL="postgresql://inaedaa:inaedaa_secret@localhost:5432/inaedaa_blast?schema=public"
POSTGRES_USER=inaedaa
POSTGRES_PASSWORD=inaedaa_secret
POSTGRES_DB=inaedaa_blast

# ---------- Redis (Queue + Cache) ----------
REDIS_URL=redis://localhost:6379

# ---------- Auth / Security ----------
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change_this_cookie_secret_min_32_chars_long
SESSION_ENCRYPTION_KEY=change_this_32_byte_hex_encryption_key_00
CSRF_SECRET=change_this_csrf_secret_min_32_chars_long
BCRYPT_SALT_ROUNDS=12

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ---------- Storage ----------
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Supabase Storage (optional — only used if STORAGE_DRIVER=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=inaedaa-media

# ---------- WhatsApp Engine ----------
WA_ENGINE=baileys
WA_SESSION_DIR=./sessions
WA_MAX_SESSIONS=5

# ---------- Queue / Campaign Defaults ----------
QUEUE_CONCURRENCY=1
DEFAULT_MIN_DELAY_SEC=5
DEFAULT_MAX_DELAY_SEC=15
MAX_MESSAGES_PER_HOUR=120
MAX_RETRY_ATTEMPTS=3
AUTO_PAUSE_FAILURE_THRESHOLD=0.4
AUTO_PAUSE_MIN_SAMPLE=15

# ---------- Frontend (apps/web) ----------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME="iNaedaa Blast"
